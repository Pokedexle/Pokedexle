{
    "name": "pokedexle",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "test:ci": "ng test --watch=false --code-coverage --code-coverage-reporters=lcov --code-coverage-reporters=text-summary",
        "lint": "eslint \"src/**/*.{ts,html}\"",
        "check:coverage": "node scripts/check-coverage.mjs",
        "check:file-naming": "node scripts/check-file-naming.mjs",
        "quality:local": "npm run lint && npm run test:ci && npm run check:coverage && npm run check:file-naming",
        "quality:ci": "npm run lint && npm run test:ci && npm run check:coverage && npm run check:file-naming && npm run build",
        "format": "prettier --write ."
    },
    "private": true,
    "engines": {
        "node": ">=22.12.0 <23"
    },
    "dependencies": {
        "@angular/common": "^20.0.0",
        "@angular/compiler": "^20.0.0",
        "@angular/core": "^20.0.0",
        "@angular/forms": "^20.0.0",
        "@angular/platform-browser": "^20.0.0",
        "@angular/router": "^20.0.0",
        "lst": "^0.1.0",
        "rxjs": "~7.8.0",
        "tslib": "^2.3.0",
        "zone.js": "~0.15.0"
    },
    "devDependencies": {
        "@angular/build": "^20.0.0",
        "@angular/cli": "^20.0.0",
        "@angular/compiler-cli": "^20.0.0",
        "@eslint/js": "^9.39.4",
        "@vitest/coverage-v8": "^3.1.1",
        "angular-eslint": "^20.0.0",
        "autoprefixer": "^10.4.0",
        "eslint": "^9.39.4",
        "jsdom": "^28.0.0",
        "postcss": "^8.4.0",
        "prettier": "^3.8.1",
        "tailwindcss": "^3.4.0",
        "typescript": "~5.9.2",
        "typescript-eslint": "^8.57.1",
        "vitest": "^3.1.1"
    }
}
