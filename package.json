{
    "name": "pokedexle",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "test:ci": "ng test --watch=false --coverage --coverage-reporters=lcov --coverage-reporters=text-summary",
        "lint": "eslint \"src/**/*.{ts,html}\"",
        "check:coverage": "node scripts/check-coverage.mjs",
        "check:file-naming": "node scripts/check-file-naming.mjs",
        "quality:local": "npm run lint && npm run test:ci && npm run check:coverage && npm run check:file-naming",
        "quality:ci": "npm run lint && npm run test:ci && npm run check:coverage && npm run check:file-naming && npm run build",
        "format": "prettier --write ."
    },
    "private": true,
    "packageManager": "npm@11.9.0",
    "engines": {
        "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
    },
    "dependencies": {
        "@angular/common": "^21.2.5",
        "@angular/compiler": "^21.2.5",
        "@angular/core": "^21.2.5",
        "@angular/forms": "^21.2.5",
        "@angular/platform-browser": "^21.2.5",
        "@angular/router": "^21.2.5",
        "rxjs": "~7.8.0",
        "tslib": "^2.3.0"
    },
    "devDependencies": {
        "@angular/build": "^21.2.3",
        "@angular/cli": "^21.2.3",
        "@angular/compiler-cli": "^21.2.5",
        "@eslint/js": "^9.39.4",
        "@vitest/coverage-v8": "^4.1.0",
        "angular-eslint": "^21.3.1",
        "eslint": "^9.39.4",
        "jsdom": "^28.0.0",
        "prettier": "^3.8.1",
        "typescript": "~5.9.2",
        "typescript-eslint": "^8.57.1",
        "vitest": "^4.0.8",
        "tailwindcss": "^3.4.0",
        "postcss": "^8.4.0",
        "autoprefixer": "^10.4.0"
    }
}
